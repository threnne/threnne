---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Threnne — independent romance publishing and tools.' } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preconnect"
      href="https://api.fontshare.com"
      crossorigin
    />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@700,500,400&f[]=spectral@400i&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
